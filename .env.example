# --- family-archive standalone production env ---
# Database
ARCHIVE_POSTGRES_DB=archive
ARCHIVE_POSTGRES_USER=archive_user
ARCHIVE_POSTGRES_PASSWORD=change-me-archive-db

# Backend
ARCHIVE_SECRET_KEY=change-me-archive-secret
ARCHIVE_COOKIE_DOMAIN=
ARCHIVE_SESSION_LIFETIME_DAYS=30
ARCHIVE_USER1_USERNAME=user1
ARCHIVE_USER1_PASSWORD=change-me-archive-user1
ARCHIVE_USER2_USERNAME=user2
ARCHIVE_USER2_PASSWORD=change-me-archive-user2

# Hetzner Object Storage (S3-compatible)
ARCHIVE_S3_ENDPOINT_URL=https://fsn1.your-objectstorage.com
ARCHIVE_S3_REGION=fsn1
ARCHIVE_S3_BUCKET=family-archive
ARCHIVE_S3_ACCESS_KEY=
ARCHIVE_S3_SECRET_KEY=
ARCHIVE_S3_FORCE_PATH_STYLE=1

# Limits
ARCHIVE_MAX_FILE_SIZE_BYTES=21474836480
ARCHIVE_CHUNK_SIZE_BYTES=8388608
ARCHIVE_TRASH_RETENTION_DAYS=30

# CORS
ARCHIVE_ALLOWED_ORIGINS=https://archive.example.com

ARCHIVE_LOG_LEVEL=INFO

