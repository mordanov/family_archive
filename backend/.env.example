# --- Database ---
DATABASE_URL=postgresql+asyncpg://archive_user:change-me@recipes-db:5432/archive

# --- Auth ---
SECRET_KEY=change-me-archive-secret
SESSION_COOKIE_NAME=archive_session
SESSION_LIFETIME_DAYS=30
COOKIE_SECURE=1
COOKIE_DOMAIN=

# --- Seeded users ---
ARCHIVE_USER1_USERNAME=user1
ARCHIVE_USER1_PASSWORD=change-me-1
ARCHIVE_USER2_USERNAME=user2
ARCHIVE_USER2_PASSWORD=change-me-2

# --- S3 / Hetzner Object Storage ---
S3_ENDPOINT_URL=https://fsn1.your-objectstorage.com
S3_REGION=fsn1
S3_BUCKET=family-archive
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=1

# --- Limits ---
MAX_FILE_SIZE_BYTES=21474836480
CHUNK_SIZE_BYTES=8388608
TRASH_RETENTION_DAYS=30
INLINE_THUMBNAIL_MAX_BYTES=52428800

# --- Misc ---
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:5173

