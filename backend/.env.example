# --- Database ---
DATABASE_URL=postgresql+asyncpg://archive_user:change-me@recipes-db:5432/archive

# --- Centralised auth service ---
AUTH_SERVICE_URL=http://auth-backend:8000
AUTH_APP_NAME=family-archive

# --- S3 / Hetzner Object Storage ---
S3_ENDPOINT_URL=https://fsn1.your-objectstorage.com
S3_REGION=fsn1
S3_BUCKET=family-archive
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=1

# --- Limits ---
MAX_FILE_SIZE_BYTES=21474836480
CHUNK_SIZE_BYTES=8388608
TRASH_RETENTION_DAYS=30
INLINE_THUMBNAIL_MAX_BYTES=52428800
THUMBNAIL_DIR=/app/data/thumbnails
THUMBNAIL_MAX_SIDE=256
PREWARM_THUMBNAIL_CONCURRENCY=4

# --- Misc ---
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:5173

